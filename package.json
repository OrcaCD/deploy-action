{
	"name": "deploy-action",
	"version": "0.1.1",
	"private": true,
	"description": "A GitHub Action to trigger deployments using OrcaCD",
	"bugs": {
		"url": "https://github.com/OrcaCD/deploy-action/issues"
	},
	"author": "",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OrcaCD/deploy-action.git"
	},
	"type": "module",
	"exports": {
		".": "./dist/index.js"
	},
	"scripts": {
		"lint": "oxlint --deny-warnings --type-aware",
		"format": "oxfmt --write .",
		"check:types": "tsc --noEmit",
		"check:format": "oxfmt --check .",
		"build": "rolldown -c rolldown.config.ts",
		"test": "node --experimental-test-module-mocks --test src/**/*.test.ts",
		"test:coverage": "node --experimental-test-module-mocks --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info --test src/**/*.test.ts"
	},
	"devDependencies": {
		"@actions/core": "^3.0.1",
		"@types/node": "^26.1.1",
		"oxfmt": "^0.59.0",
		"oxlint": "^1.74.0",
		"oxlint-tsgolint": "^0.25.0",
		"rolldown": "^1.2.0",
		"typescript": "^7.0.2"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@11.6.0"
}
