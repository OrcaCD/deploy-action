{
	"include": ["src/**/*.ts", "./rolldown.config.ts"],
	"exclude": ["node_modules/"],
	"compilerOptions": {
		"outDir": "dist",
		"strict": true,
		"checkJs": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,

		"rootDir": ".",
		"target": "esnext",
		"module": "nodenext",
		"rewriteRelativeImportExtensions": true,
		"erasableSyntaxOnly": true,
		"verbatimModuleSyntax": true
	}
}
